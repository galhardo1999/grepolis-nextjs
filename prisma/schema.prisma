generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  createdAt DateTime @default(now())

  cidade   Cidade?
  sessions Session[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @db.Timestamptz
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Cidade {
  id              String   @id @default(cuid())
  userId          String   @unique
  nomeCidade      String   @default("Granpolis")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Recursos — Int para evitar erros de arredundamento Float
  madeira         Int      @default(250)
  pedra           Int      @default(250)
  prata           Int      @default(250)
  populacao       Int      @default(100)
  populacaoMaxima Int      @default(100)
  recursosMaximos Int      @default(300)
  favor           Int      @default(0)
  favorMaximo     Int      @default(500)
  prataNaGruta    Int      @default(0)

  // Deus atual
  deusAtual       String?

  // Edificios (JSON: { senate: 1, timberCamp: 0, ... })
  edificios       Json     @default("{}")

  // Unidades (JSON: { swordsman: 0, slinger: 0, ... })
  unidades        Json     @default("{}")

  // Pesquisas concluídas
  pesquisasConcluidas String[] @default([])

  // Missões coletadas
  missoesColetadas    String[] @default([])

  // Fila de construção
  fila            Json     @default("[]")

  // Fila de recrutamento
  filaRecrutamento Json    @default("[]")

  // Cooldowns de aldeias
  cooldownsAldeias Json    @default("{}")

  ultimaAtualizacao DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([ultimaAtualizacao])
}
